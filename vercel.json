{
  "functions": {
    "api/index.php": { "runtime": "vercel-php@0.9.0" },
    "api/dashboard.php": { "runtime": "vercel-php@0.9.0" },
    "api/pos.php": { "runtime": "vercel-php@0.9.0" },
    "api/catalogo.php": { "runtime": "vercel-php@0.9.0" },
    "api/clientes.php": { "runtime": "vercel-php@0.9.0" },
    "api/historial.php": { "runtime": "vercel-php@0.9.0" },
    "api/factura.php": { "runtime": "vercel-php@0.9.0" },
    "api/backend/procesar_login.php": { "runtime": "vercel-php@0.9.0" },
    "api/backend/logout.php": { "runtime": "vercel-php@0.9.0" },
    "api/backend/api_productos.php": { "runtime": "vercel-php@0.9.0" }
  },
  "routes": [
    { "src": "/$", "dest": "/api/index.php" },
    { "src": "/frontend/(.*)", "dest": "/frontend/$1" },
    { "src": "/backend/(.*)", "dest": "/api/backend/$1" },
    { "src": "/(.*)", "dest": "/api/$1" }
  ]
}
